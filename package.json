{
  "name": "upnext-frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --fix",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "format": "node ./node_modules/prettier/bin/prettier.cjs . --write --ignore-unknown",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs . --check --ignore-unknown",
    "test": "node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "node ./node_modules/vitest/vitest.mjs",
    "validate": "node ./node_modules/eslint/bin/eslint.js . && node ./node_modules/typescript/bin/tsc --noEmit && node ./node_modules/vitest/vitest.mjs run && node ./node_modules/prettier/bin/prettier.cjs . --check --ignore-unknown",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.11",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "node ./node_modules/eslint/bin/eslint.js --fix",
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ],
    "*.{json,css,md,yml,yaml}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  }
}
